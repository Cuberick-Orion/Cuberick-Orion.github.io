---
import type { HTMLAttributes } from 'astro/types'

type Props = HTMLAttributes<'header'>

const { class: className, ...attrs } = Astro.props

const { title, author, socials, navs } = Astro.locals.config

const { translate: t } = Astro.locals

const homeSectionByHref: Record<string, string> = {
  '#profile-top': 'about',
  '#news': 'about',
  '#recent-research': 'publications',
  '#affiliations': 'affiliations',
  '#links': 'links',
}
---

<header un-lg="grow-1 justify-between items-start" un-flex="~ col gap-2.5" class:list={['site-sidebar', 'text-center', className]} {...attrs}>
  <hgroup
    un-hover:lg="bg-foreground color-background pt-3.75 pb-8.75 "
    un-lg=" write-vertical-right items-start px-2.5 pb-12 b-l-2px b-l-foreground-solid text-left"
    un-flex="~ col gap-2.5"
    class="site-sidebar-title-card cursor-pointer transition-[padding,background] duration-800 ease-in-out"
  >
    <a class="normal" href="/">
      <h3 class="text-5 font-extrabold font-serif">{author}</h3>
      <h1 class="text-8 font-extrabold font-serif">{title}</h1>
    </a>
  </hgroup>

  <nav class="site-nav text-center font-bold" un-flex="~ col gap-2">
    <ul un-lg="flex-col items-start text-4" class="text-3.5" un-flex="~ row gap-2 justify-center">
      {
        navs.map((nav) => {
          const homeSection = homeSectionByHref[nav.href]

          return (
          <li>
            <a
              class="site-sidebar-link"
              href={nav.href}
              data-home-section-nav={homeSection}
              data-home-section-target={nav.href}
              aria-current={nav.href === '#profile-top' ? 'page' : undefined}
            >
              <span class="site-sidebar-link-sweep" aria-hidden="true"></span>
              <span class="site-sidebar-link-label">{t(nav.name)}</span>
            </a>
          </li>
        )})
      }
    </ul>
    <ul un-flex="~ row gap-1.5 justify-center">
      {
        socials.map((soc) => (
          <li>
            <a href={soc.href} target="_blank" title={soc.title} class={`site-sidebar-social-link icon ${soc.iconlink}`} />
          </li>
        ))
      }
    </ul>
  </nav>
</header>
