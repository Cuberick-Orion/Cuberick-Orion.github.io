---
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'

interface Props {
  image: ImageMetadata
  alt: string
}

const { image, alt } = Astro.props
---

<div class="research-item">
  <div class="research-item__media">
    <Image class="research-item__image" src={image} alt={alt} />
  </div>
  <div class="research-item__body">
    <slot />
  </div>
</div>
