  <script is:inline>
    (() => {
      const bindProgressiveText = () => {
        const root = document.querySelector('[data-home-progressive-column]');
        if (!(root instanceof HTMLElement)) {
          return;
        }

        const reduceMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const progressiveTargetSelector = '[data-home-progressive-text="true"], [data-home-progressive-visual="true"], [data-home-progressive-plate="true"]';
        const digitalGlyphs = '0123456789@#$%&*+=?<>/\\|!;:~';
        const digitalEnterRate = 0.09;
        const aboutDigitalEnterRate = 0.07;
        const panelSelector = '[data-home-section-panel]';
        const sectionKeyByHash = {
          '#profile-top': 'about',
          '#about': 'about',
          '#news': 'about',
          '#recent-research': 'publications',
          '#affiliations': 'affiliations',
          '#links': 'links',
        };
        const sectionHashByKey = {
          about: '#profile-top',
          publications: '#recent-research',
          affiliations: '#affiliations',
          links: '#links',
        };
        const revealLeadDelay = 72;
        const collapseRevealLeadDelay = 48;
        const revealStagger = 34;
        const exitStagger = 0;
        const exitFallbackBase = 380;
        let activeObserver = null;
        let isSwitching = false;
        let queuedSelection = null;

        const getPanels = () => Array.from(root.querySelectorAll(panelSelector))
          .filter((panel) => panel instanceof HTMLElement);
        const getPanel = (key) => getPanels()
          .find((panel) => panel instanceof HTMLElement && panel.dataset.homeSectionPanel === key);
        const normalizeSection = (key) => (key && getPanel(key) ? key : 'about');
        const getSectionFromHash = () => sectionKeyByHash[window.location.hash] ?? 'about';
        const getTargetHash = (key, fallbackHash) => fallbackHash || sectionHashByKey[key] || '#profile-top';
        const normalizeHash = (hash) => (hash && hash.startsWith('#') ? hash : '');
        const digitalEnterRateFor = (element) => (
          element.closest('[data-home-section-panel]')?.dataset.homeSectionPanel === 'about'
            ? aboutDigitalEnterRate
            : digitalEnterRate
        );
        const getPanelTargets = (panel) => Array.from(panel.querySelectorAll(progressiveTargetSelector))
          .filter((element) => element instanceof HTMLElement);
        const navLinks = Array.from(document.querySelectorAll('[data-home-section-nav]'))
          .filter((link) => link instanceof HTMLAnchorElement);
        const isDigitalEligibleChar = (char) => /^[A-Za-z0-9]$/.test(char);
        const randomDigitalGlyph = () => digitalGlyphs[Math.floor(Math.random() * digitalGlyphs.length)];
        const isIconElement = (element) => {
          if (!(element instanceof HTMLElement)) {
            return false;
          }

          return Array.from(element.classList).some((className) => className.startsWith('i-'));
        };

        const collectDigitalTextNodes = (element) => {
          const walker = document.createTreeWalker(
            element,
            NodeFilter.SHOW_TEXT,
            {
              acceptNode(node) {
                const parent = node.parentElement;
                const ariaHiddenAncestor = parent?.closest('[aria-hidden="true"]');
                if (
                  !parent ||
                  isIconElement(parent) ||
                  parent.closest('script, style, svg, .home-digital-word, .home-digital-glyph') ||
                  (ariaHiddenAncestor && !ariaHiddenAncestor.matches('[data-home-section-panel]'))
                ) {
                  return NodeFilter.FILTER_REJECT;
                }

                return (node.nodeValue || '').trim()
                  ? NodeFilter.FILTER_ACCEPT
                  : NodeFilter.FILTER_REJECT;
              },
            }
          );
          const textNodes = [];
          while (walker.nextNode()) {
            textNodes.push(walker.currentNode);
          }

          return textNodes;
        };

        const activateDigitalTextNode = (node, activeRate) => {
          const text = node.nodeValue || '';
          if (!text.trim()) {
            return [];
          }

          const fragment = document.createDocumentFragment();
          const activeGlyphs = [];
          text.split(/(\s+)/).forEach((token) => {
            if (!token) {
              return;
            }

            if (/^\s+$/.test(token)) {
              fragment.appendChild(document.createTextNode(token));
              return;
            }

            const chars = Array.from(token);
            const activeIndexes = new Set();
            chars.forEach((char, index) => {
              if (isDigitalEligibleChar(char) && Math.random() < activeRate) {
                activeIndexes.add(index);
              }
            });

            if (activeIndexes.size === 0) {
              fragment.appendChild(document.createTextNode(token));
              return;
            }

            const word = document.createElement('span');
            word.className = 'home-digital-word';
            let plainText = '';
            const flushPlainText = () => {
              if (!plainText) {
                return;
              }

              word.appendChild(document.createTextNode(plainText));
              plainText = '';
            };

            chars.forEach((char, index) => {
              if (!activeIndexes.has(index)) {
                plainText += char;
                return;
              }

              flushPlainText();
              const glyph = document.createElement('span');
              glyph.className = 'home-digital-glyph';
              glyph.dataset.homeDigitalFinal = char;
              glyph.textContent = char;
              word.appendChild(glyph);
              activeGlyphs.push(glyph);
            });
            flushPlainText();
            fragment.appendChild(word);
          });

          if (activeGlyphs.length === 0) {
            return [];
          }

          node.parentNode?.replaceChild(fragment, node);
          return activeGlyphs;
        };

        const prepareDigitalText = (element) => {
          if (!(element instanceof HTMLElement) || element.dataset.homeDigitalText === 'true') {
            return;
          }

          element.dataset.homeDigitalText = 'true';
        };

        const restoreDigitalText = (element) => {
          if (!(element instanceof HTMLElement)) {
            return;
          }

          element.querySelectorAll('.home-digital-glyph').forEach((glyph) => {
            if (!(glyph instanceof HTMLElement)) {
              return;
            }

            const finalText = glyph.dataset.homeDigitalFinal || glyph.textContent || '';
            glyph.textContent = finalText;
            glyph.classList.remove('is-home-digital', 'is-home-digital-resolving');
          });

          const parentsToNormalize = new Set();
          element.querySelectorAll('.home-digital-word').forEach((word) => {
            if (!(word instanceof HTMLElement)) {
              return;
            }

            const parent = word.parentNode;
            if (parent) {
              parentsToNormalize.add(parent);
            }
            word.replaceWith(document.createTextNode(word.textContent || ''));
          });
          parentsToNormalize.forEach((parent) => parent.normalize());
        };

        const createActiveDigitalGlyphs = (element, activeRate) => {
          restoreDigitalText(element);
          return collectDigitalTextNodes(element).flatMap((node) => activateDigitalTextNode(node, activeRate));
        };

        const runDigitalEnter = (element, delayOverride) => {
          if (!(element instanceof HTMLElement) || element.dataset.homeDigitalText !== 'true' || reduceMotion()) {
            return;
          }

          const activeGlyphs = createActiveDigitalGlyphs(element, digitalEnterRateFor(element));
          if (activeGlyphs.length === 0) {
            return;
          }

          const runId = `${Date.now()}-${Math.random()}`;
          const delayMs = Number.isFinite(delayOverride)
            ? delayOverride
            : Number.parseFloat(element.style.getPropertyValue('--home-op-delay')) || 0;
          element.dataset.homeDigitalRun = runId;

          window.setTimeout(() => {
            if (element.dataset.homeDigitalRun !== runId || element.dataset.homeProgressiveState !== 'playing') {
              return;
            }

            const activeRate = digitalEnterRateFor(element);
            activeGlyphs.forEach((glyph) => {
              glyph.textContent = randomDigitalGlyph();
              glyph.classList.add('is-home-digital');
            });

            [0, 48, 96].forEach((tickDelay, tickIndex) => {
              window.setTimeout(() => {
                if (element.dataset.homeDigitalRun !== runId) {
                  return;
                }

                activeGlyphs.forEach((glyph, index) => {
                  if ((index + tickIndex) % 2 === 0 || Math.random() < activeRate) {
                    glyph.textContent = randomDigitalGlyph();
                  }
                });
              }, tickDelay);
            });

            const resolvingGroups = new Map();
            activeGlyphs.forEach((glyph, index) => {
              const burstDelay = (index % 3 === 0 ? 126 : 198) + (index % 6) * 12;
              const group = resolvingGroups.get(burstDelay) || [];
              group.push(glyph);
              resolvingGroups.set(burstDelay, group);
            });

            let latestBurstDelay = 0;
            resolvingGroups.forEach((glyphs, burstDelay) => {
              latestBurstDelay = Math.max(latestBurstDelay, burstDelay);
              window.setTimeout(() => {
                if (element.dataset.homeDigitalRun !== runId) {
                  return;
                }

                glyphs.forEach((glyph) => {
                  glyph.textContent = glyph.dataset.homeDigitalFinal || glyph.textContent || '';
                  glyph.classList.remove('is-home-digital');
                  glyph.classList.add('is-home-digital-resolving');
                });
                window.setTimeout(() => {
                  if (element.dataset.homeDigitalRun !== runId) {
                    return;
                  }
                  glyphs.forEach((glyph) => {
                    glyph.classList.remove('is-home-digital-resolving');
                  });
                }, 50);
              }, burstDelay);
            });

            window.setTimeout(() => {
              if (element.dataset.homeDigitalRun !== runId) {
                return;
              }

              restoreDigitalText(element);
              element.removeAttribute('data-home-digital-run');
            }, latestBurstDelay + 70);
          }, delayMs + 78);
        };

        const clearActiveObserver = () => {
          if (activeObserver) {
            activeObserver.disconnect();
            activeObserver = null;
          }
        };

        const resetElement = (element) => {
          element.dataset.homeProgressiveState = 'waiting';
          element.removeAttribute('data-home-digital-run');
          restoreDigitalText(element);
          element.style.removeProperty('--home-op-delay');
          element.style.removeProperty('--home-op-exit-delay');
        };

        const startElement = (element, delayOverride) => {
          if (!(element instanceof HTMLElement) || element.dataset.homeProgressiveState !== 'waiting') {
            return;
          }

          if (delayOverride != null) {
            element.style.setProperty('--home-op-delay', `${delayOverride}ms`);
          }

          element.style.removeProperty('--home-op-exit-delay');
          element.dataset.homeProgressiveState = reduceMotion() ? 'entered' : 'playing';
          runDigitalEnter(element, delayOverride);
        };

        const exitElement = (element, delayOverride) => {
          if (!(element instanceof HTMLElement) || element.dataset.homeProgressiveState === 'waiting') {
            return false;
          }

          if (reduceMotion()) {
            resetElement(element);
            return false;
          }

          element.style.setProperty('--home-op-exit-delay', `${delayOverride}ms`);
          element.style.removeProperty('--home-op-delay');
          element.dataset.homeProgressiveState = 'exiting';
          return true;
        };

        const replayNavAnimation = (link, transition) => {
          if (!(link instanceof HTMLElement) || reduceMotion()) {
            return;
          }

          link.removeAttribute('data-home-section-transition');
          link.removeAttribute('data-home-section-deco');
          void link.offsetWidth;
          link.dataset.homeSectionTransition = transition;
          if (transition === 'activate') {
            link.dataset.homeSectionDeco = 'replay';
          }

          window.setTimeout(() => {
            if (link.dataset.homeSectionTransition === transition) {
              link.removeAttribute('data-home-section-transition');
            }
            if (link.dataset.homeSectionDeco === 'replay') {
              link.removeAttribute('data-home-section-deco');
            }
          }, 860);
        };

        const setNavState = (key, targetHash = '') => {
          const activeHash = normalizeHash(targetHash);
          navLinks.forEach((link) => {
            const linkHash = normalizeHash(link.dataset.homeSectionTarget || link.getAttribute('href') || '');
            const isActive = activeHash
              ? linkHash === activeHash
              : link.dataset.homeSectionNav === key;
            const wasActive = link.dataset.homeSectionActive === 'true';
            link.dataset.homeSectionActive = String(isActive);
            link.toggleAttribute('aria-current', isActive);
            if (isActive) {
              link.setAttribute('aria-current', 'page');
            }

            if (wasActive !== isActive) {
              replayNavAnimation(link, isActive ? 'activate' : 'deactivate');
            }
          });
        };

        const setPanelState = (key, targetHash = '') => {
          getPanels().forEach((panel) => {
            const isActive = panel.dataset.homeSectionPanel === key;
            panel.dataset.homeSectionState = isActive ? 'active' : 'inactive';
            panel.hidden = !isActive;
            panel.setAttribute('aria-hidden', String(!isActive));
          });

          root.dataset.homeActiveSection = key;
          setNavState(key, targetHash);
        };

        const revealRoot = () => {
          root.removeAttribute('data-home-progressive-pending');
        };

        const activatePanelTargets = (panel) => {
          clearActiveObserver();
          if (!(panel instanceof HTMLElement)) {
            return;
          }

          const targets = getPanelTargets(panel)
            .filter((element) => element.dataset.homeProgressiveState === 'waiting');
          const deferredTargets = [];
          let visibleIndex = 0;

          targets.forEach((element) => {
            const rect = element.getBoundingClientRect();
            const isVisibleNow = rect.bottom > 0 && rect.top < window.innerHeight * 0.96 && rect.width > 0 && rect.height > 0;

            if (isVisibleNow) {
              startElement(element, revealLeadDelay + visibleIndex * revealStagger);
              visibleIndex += 1;
              return;
            }

            deferredTargets.push(element);
          });

          if (!('IntersectionObserver' in window)) {
            deferredTargets.forEach((element, index) => startElement(element, revealLeadDelay + (visibleIndex + index) * revealStagger));
            return;
          }

          activeObserver = new IntersectionObserver((entries) => {
            entries
              .filter((entry) => entry.isIntersecting)
              .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top)
              .forEach((entry, index) => {
                if (activeObserver) {
                  activeObserver.unobserve(entry.target);
                }
                startElement(entry.target, revealLeadDelay + (visibleIndex + index) * revealStagger);
              });
          }, { threshold: 0.12, rootMargin: '0px 0px -4% 0px' });

          deferredTargets.forEach((element) => {
            activeObserver.observe(element);
          });
        };

        const resetPanelTargets = (panel) => {
          if (!(panel instanceof HTMLElement)) {
            return;
          }

          getPanelTargets(panel).forEach(resetElement);
        };

        const exitPanelTargets = (panel) => new Promise((resolve) => {
          if (!(panel instanceof HTMLElement) || reduceMotion()) {
            if (panel instanceof HTMLElement) {
              resetPanelTargets(panel);
            }
            resolve();
            return;
          }

          const exitingTargets = getPanelTargets(panel)
            .filter((element) => element.dataset.homeProgressiveState !== 'waiting');

          if (exitingTargets.length === 0) {
            resolve();
            return;
          }

          exitingTargets.forEach((element, index) => {
            exitElement(element, index * exitStagger);
          });

          window.setTimeout(resolve, exitFallbackBase + exitingTargets.length * exitStagger);
        });

        const getScrollTarget = (targetHash) => {
          const hash = normalizeHash(targetHash);
          if (!hash) {
            return root;
          }

          const target = document.getElementById(decodeURIComponent(hash.slice(1)));
          return target instanceof HTMLElement ? target : root;
        };

        const scrollPanelIntoView = (targetHash = '') => {
          const target = getScrollTarget(targetHash);
          const rect = target.getBoundingClientRect();
          if (rect.top < 0 || rect.top > window.innerHeight * 0.28) {
            window.scrollTo({
              top: Math.max(0, window.scrollY + rect.top),
              behavior: reduceMotion() ? 'auto' : 'smooth',
            });
          }
        };

        const showPanel = (key, targetHash = '', options = {}) => {
          const panel = getPanel(key);
          if (!(panel instanceof HTMLElement)) {
            return;
          }

          resetPanelTargets(panel);
          setPanelState(key, targetHash);
          if (options.scrollToTarget) {
            scrollPanelIntoView(targetHash);
          }
          window.requestAnimationFrame(() => {
            activatePanelTargets(panel);
            document.dispatchEvent(new CustomEvent('home-section-change', { detail: { section: key } }));
          });
        };

        const selectSection = async (requestedKey, options = {}) => {
          const key = normalizeSection(requestedKey);
          const {
            updateHash = true,
            animate = true,
            targetHash: requestedTargetHash = '',
            scrollToTarget = false,
          } = options;
          const targetHash = getTargetHash(key, requestedTargetHash);

          if (isSwitching) {
            queuedSelection = { key, targetHash, updateHash, animate, scrollToTarget };
            return;
          }

          const currentKey = normalizeSection(root.dataset.homeActiveSection);
          if (key === currentKey) {
            setNavState(key, targetHash);
            if (scrollToTarget) {
              scrollPanelIntoView(targetHash);
            }
            if (updateHash && targetHash) {
              history.replaceState(null, '', targetHash);
            }
            return;
          }

          const currentPanel = getPanel(currentKey);
          const nextPanel = getPanel(key);
          if (!(nextPanel instanceof HTMLElement)) {
            return;
          }

          if (updateHash && targetHash) {
            history.pushState(null, '', targetHash);
          }

          setNavState(key, targetHash);
          clearActiveObserver();
          isSwitching = true;

          if (animate) {
            await exitPanelTargets(currentPanel);
          }

          if (currentPanel instanceof HTMLElement) {
            resetPanelTargets(currentPanel);
          }

          showPanel(key, targetHash, { scrollToTarget });
          isSwitching = false;

          if (queuedSelection && (queuedSelection.key !== key || queuedSelection.targetHash !== targetHash)) {
            const nextQueuedSelection = queuedSelection;
            queuedSelection = null;
            selectSection(nextQueuedSelection.key, {
              updateHash: nextQueuedSelection.updateHash,
              animate: nextQueuedSelection.animate,
              targetHash: nextQueuedSelection.targetHash,
              scrollToTarget: nextQueuedSelection.scrollToTarget,
            });
            return;
          }

          queuedSelection = null;
        };

        const playRevealedContent = (content) => {
          if (!(content instanceof HTMLElement)) {
            return;
          }

          const revealedTargets = content.matches(progressiveTargetSelector)
            ? [content]
            : [];
          revealedTargets.push(...content.querySelectorAll(progressiveTargetSelector));

          revealedTargets.forEach((element, index) => {
            startElement(element, collapseRevealLeadDelay + index * revealStagger);
          });
        };

        const getDetailsBodyTargets = (details) => Array.from(details.querySelectorAll(progressiveTargetSelector))
          .filter((element) => element instanceof HTMLElement && !element.closest('summary'));

        const playDetailsBodyContent = (details) => {
          getDetailsBodyTargets(details).forEach((element, index) => {
            startElement(element, collapseRevealLeadDelay + index * revealStagger);
          });
        };

        const exitDetailsBodyContent = (details) => {
          getDetailsBodyTargets(details).forEach((element, index) => {
            exitElement(element, index * exitStagger);
          });
        };

        const animateAffiliationDetails = (details, shouldOpen) => {
          const summary = details.querySelector('summary');
          const body = details.querySelector('.affiliation-role-details-body');
          if (!(summary instanceof HTMLElement) || !(body instanceof HTMLElement)) {
            details.open = shouldOpen;
            return;
          }

          if (details.dataset.affiliationDetailsAnimating === 'true') {
            return;
          }

          if (reduceMotion()) {
            details.open = shouldOpen;
            details.dataset.affiliationDetailsExpanded = String(shouldOpen);
            details.dispatchEvent(new CustomEvent(`home-progressive-details-${shouldOpen ? 'open' : 'close'}`, { bubbles: true }));
            return;
          }

          details.open = true;
          details.dataset.affiliationDetailsAnimating = 'true';
          details.classList.add('affiliation-details-animating');

          const getExpandedHeight = () => {
            const bodyStyle = window.getComputedStyle(body);
            const bodyMarginTop = Number.parseFloat(bodyStyle.marginTop) || 0;
            const bodyMarginBottom = Number.parseFloat(bodyStyle.marginBottom) || 0;
            return Math.ceil(summary.offsetHeight + bodyMarginTop + body.scrollHeight + bodyMarginBottom);
          };

          let cleanupTimer = 0;
          const finish = () => {
            window.clearTimeout(cleanupTimer);
            details.removeEventListener('transitionend', onTransitionEnd);
            details.open = shouldOpen;
            details.classList.remove('affiliation-details-animating');
            details.style.height = '';
            body.style.opacity = '';
            body.style.transform = '';
            details.dataset.affiliationDetailsAnimating = 'false';
            details.dataset.affiliationDetailsExpanded = String(shouldOpen);
          };

          const onTransitionEnd = (event) => {
            if (event.target === details && event.propertyName === 'height') {
              finish();
            }
          };

          details.addEventListener('transitionend', onTransitionEnd);

          if (shouldOpen) {
            const startHeight = summary.offsetHeight;
            const targetHeight = getExpandedHeight();
            body.style.opacity = '0';
            body.style.transform = 'translateY(-4px)';
            details.style.height = `${startHeight}px`;
            details.offsetHeight;
            details.dispatchEvent(new CustomEvent('home-progressive-details-open', { bubbles: true }));
            window.requestAnimationFrame(() => {
              details.style.height = `${targetHeight}px`;
              body.style.opacity = '1';
              body.style.transform = 'translateY(0)';
            });
          } else {
            const startHeight = getExpandedHeight();
            const targetHeight = summary.offsetHeight;
            details.style.height = `${startHeight}px`;
            body.style.opacity = '1';
            body.style.transform = 'translateY(0)';
            details.offsetHeight;
            details.dispatchEvent(new CustomEvent('home-progressive-details-close', { bubbles: true }));
            window.requestAnimationFrame(() => {
              details.style.height = `${targetHeight}px`;
              body.style.opacity = '0';
              body.style.transform = 'translateY(-4px)';
            });
          }

          cleanupTimer = window.setTimeout(finish, 420);
        };

        const bindDetailsRevealAnimations = () => {
          if (root.dataset.homeProgressiveDetailsBound === 'true') {
            return;
          }

          root.dataset.homeProgressiveDetailsBound = 'true';
          root.addEventListener('home-progressive-details-open', (event) => {
            const target = event.target;
            if (target instanceof HTMLElement) {
              window.requestAnimationFrame(() => {
                playDetailsBodyContent(target);
              });
            }
          });
          root.addEventListener('home-progressive-details-close', (event) => {
            const target = event.target;
            if (target instanceof HTMLElement) {
              exitDetailsBodyContent(target);
            }
          });

          root.querySelectorAll('details.affiliation-role-details > summary').forEach((summary) => {
            if (!(summary instanceof HTMLElement)) {
              return;
            }

            const details = summary.parentElement;
            if (!(details instanceof HTMLDetailsElement) || details.dataset.affiliationDetailsBound === 'true') {
              return;
            }

            details.dataset.affiliationDetailsBound = 'true';
            details.dataset.affiliationDetailsExpanded = String(details.open);
            summary.addEventListener('click', (event) => {
              event.preventDefault();
              event.stopPropagation();
              animateAffiliationDetails(details, details.dataset.affiliationDetailsExpanded !== 'true');
            }, { capture: true });
          });
        };

        const bindCollapseRevealAnimations = () => {
          root.querySelectorAll('[data-collapse-target]').forEach((button) => {
            if (!(button instanceof HTMLElement) || button.dataset.homeProgressiveCollapseBound === 'true') {
              return;
            }

            button.dataset.homeProgressiveCollapseBound = 'true';
            button.addEventListener('click', () => {
              const targetId = button.getAttribute('data-collapse-target');
              if (!targetId) {
                return;
              }

              window.requestAnimationFrame(() => {
                const content = document.getElementById(targetId);
                if (content instanceof HTMLElement && content.classList.contains('open')) {
                  playRevealedContent(content);
                }
              });
            });
          });
        };

        const bindSectionNavigation = () => {
          navLinks.forEach((link) => {
            if (link.dataset.homeSectionNavBound === 'true') {
              return;
            }

            link.dataset.homeSectionNavBound = 'true';
            link.addEventListener('click', (event) => {
              const key = link.dataset.homeSectionNav;
              if (!key) {
                return;
              }

              event.preventDefault();
              const targetHash = normalizeHash(link.dataset.homeSectionTarget || link.getAttribute('href') || '');
              selectSection(key, {
                targetHash,
                scrollToTarget: true,
              });
            });
          });

          if (root.dataset.homePopstateBound !== 'true') {
            root.dataset.homePopstateBound = 'true';
            window.addEventListener('popstate', () => {
              selectSection(getSectionFromHash(), {
                updateHash: false,
                targetHash: window.location.hash,
              });
            });
          }
        };

        const revealAndActivate = () => {
          const initialSection = normalizeSection(getSectionFromHash());
          const initialTargetHash = getTargetHash(initialSection, window.location.hash);
          setPanelState(initialSection, initialTargetHash);
          revealRoot();
          bindCollapseRevealAnimations();
          bindDetailsRevealAnimations();
          bindSectionNavigation();
          activatePanelTargets(getPanel(initialSection));
          if (initialTargetHash && initialTargetHash !== '#profile-top') {
            window.requestAnimationFrame(() => {
              scrollPanelIntoView(initialTargetHash);
            });
          }
          document.dispatchEvent(new CustomEvent('home-section-change', { detail: { section: initialSection } }));
        };

        const whenTypographyReady = (callback) => {
          if (document.fonts?.ready) {
            document.fonts.ready.then(callback, callback);
            return;
          }

          callback();
        };

        if (root.dataset.homeProgressiveTextBound === 'true') {
          whenTypographyReady(revealAndActivate);
          return;
        }

        const prepare = (element, delay, options = {}) => {
          const {
            flag = 'homeProgressiveText',
            className = 'op-credit--home-name-line',
            animationName = 'home-op-name-enter',
            exitAnimationName = 'home-op-name-exit',
            enterSettleDelay = null,
          } = options;

          if (!(element instanceof HTMLElement) || element.dataset[flag] === 'true') {
            return;
          }

          if (flag === 'homeProgressiveText' && element.parentElement?.closest('[data-home-progressive-text="true"]')) {
            return;
          }

          element.dataset[flag] = 'true';
          element.dataset.homeProgressiveState = 'waiting';
          element.dataset.homeProgressiveEnterAnimation = animationName;
          element.dataset.homeProgressiveExitAnimation = exitAnimationName;
          element.style.setProperty('--home-op-delay', `${delay}ms`);
          element.classList.add(className);
          if (flag === 'homeProgressiveText') {
            prepareDigitalText(element);
          }

          element.addEventListener('animationend', (event) => {
            if (event.animationName === element.dataset.homeProgressiveEnterAnimation && element.dataset.homeProgressiveState === 'playing') {
              const settleDelay = enterSettleDelay ?? (
                element.classList.contains('home-plate-title') ||
                element.classList.contains('home-copy-plate') ||
                element.classList.contains('home-publication-plate')
                  ? (element.classList.contains('home-plate-title') ? 1280 : 820)
                  : 0
              );

              if (settleDelay > 0) {
                window.setTimeout(() => {
                  if (element.dataset.homeProgressiveState === 'playing') {
                    element.dataset.homeProgressiveState = 'entered';
                  }
                }, settleDelay);
                return;
              }

              element.dataset.homeProgressiveState = 'entered';
              return;
            }

            if (event.animationName === element.dataset.homeProgressiveExitAnimation && element.dataset.homeProgressiveState === 'exiting') {
              resetElement(element);
            }
          });
        };

        const prepareAll = (selector, baseDelay, step = 34, prepareTarget = prepare) => {
          root.querySelectorAll(selector).forEach((element, index) => {
            prepareTarget(element, baseDelay + index * step);
          });
        };

        root.dataset.homeProgressiveTextBound = 'true';

        const prepareVisual = (element, delay) => {
          prepare(element, delay, {
            flag: 'homeProgressiveVisual',
            className: 'op-credit--home-visual',
            animationName: 'home-op-visual-enter',
            exitAnimationName: 'home-op-visual-exit',
          });
        };

        const preparePlate = (element, delay) => {
          prepare(element, delay, {
            flag: 'homeProgressivePlate',
            className: 'home-progressive-plate',
            animationName: 'home-op-plate-enter',
            exitAnimationName: 'home-op-plate-exit',
          });
        };

        prepareAll('#profile-top .home-copy-plate--about', 0, 34, preparePlate);
        prepareAll('#research-interest [data-hscroll-content] li', 34, 34);

        const hasTextContent = (element) => (element.textContent || '').trim().length > 0;
        const isVisualTarget = (element) => element instanceof HTMLElement && element.matches('img, .affiliation-logo');
        const keepTopLevelTargets = (elements) => elements.filter((element, index, list) => (
          element instanceof HTMLElement &&
          (isVisualTarget(element) || hasTextContent(element)) &&
          !list.some((other, otherIndex) => (
            otherIndex !== index &&
            other instanceof HTMLElement &&
            other.contains(element)
          ))
        ));

        root.querySelectorAll('[data-home-progressive-section]').forEach((section, sectionIndex) => {
          const baseDelay = 160 + sectionIndex * 48;
          const plateSelectors = [
            ':scope > article.heti > .home-copy-plate',
            ':scope .home-publication-plate'
          ].join(',');
          section.querySelectorAll(plateSelectors).forEach((element, index) => {
            preparePlate(element, Math.max(0, baseDelay - 48) + index * 34);
          });

          const progressiveSelectors = [
            ':scope > article.heti > h5',
            ':scope > article.heti > p',
            ':scope > article.heti > article > p',
            ':scope img',
            ':scope .affiliation-logo',
            ':scope .home-contact-line',
            ':scope .home-research-interest-list > li',
            '.news-entry',
            '.collapse-toggle-wrap',
            '.research_h1 > strong',
            '.research_h1 > span',
            '.research_h1 > p',
            '.research_h1 details > summary',
            '.research_h1 details > p',
            '.research_h1 details pre',
            '.affiliation-meta',
            '.affiliation-role-primary',
            '.affiliation-role-details > summary',
            '.affiliation-role-details-body > div',
            '.affiliation-role-details-body li',
            '.affiliation-role-secondary',
            '.related-link-title',
            '.related-link-actions',
            '.related-link-actions--text'
          ].join(',');

          keepTopLevelTargets(Array.from(section.querySelectorAll(progressiveSelectors))).forEach((element, index) => {
            const delay = baseDelay + index * 34;

            if (element.matches('img, .affiliation-logo')) {
              prepareVisual(element, delay);
              return;
            }

            prepare(element, delay);
          });
        });

        whenTypographyReady(revealAndActivate);
      };

      const bindHorizontalIndicator = () => {
        document.querySelectorAll('[data-hscroll-panel]').forEach((panel) => {
          if (!(panel instanceof HTMLElement) || panel.dataset.hscrollBound === 'true') {
            return;
          }

          const content = panel.querySelector('[data-hscroll-content]');
          const indicator = panel.parentElement?.querySelector('[data-hscroll-indicator]');
          if (!(content instanceof HTMLElement) || !(indicator instanceof HTMLElement)) {
            return;
          }

          let hasScrolledRight = false;

          const updateIndicator = () => {
            if (panel.scrollLeft > 0) {
              hasScrolledRight = true;
            }

            const hasOverflow = content.scrollWidth > panel.clientWidth + 1;
            const shouldShow = hasOverflow && !hasScrolledRight;
            indicator.style.opacity = shouldShow ? '1' : '0';
            indicator.style.visibility = shouldShow ? 'visible' : 'hidden';
          };

          panel.dataset.hscrollBound = 'true';
          updateIndicator();
          requestAnimationFrame(updateIndicator);
          setTimeout(updateIndicator, 120);
          panel.addEventListener('scroll', updateIndicator, { passive: true });
          window.addEventListener('resize', updateIndicator, { passive: true });
          window.addEventListener('load', updateIndicator, { passive: true });

          if ('ResizeObserver' in window) {
            const observer = new ResizeObserver(updateIndicator);
            observer.observe(panel);
          }
        });
      };

      bindProgressiveText();

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bindHorizontalIndicator, { once: true });
      } else {
        bindHorizontalIndicator();
      }

      document.addEventListener('astro:page-load', bindProgressiveText);
      document.addEventListener('astro:page-load', bindHorizontalIndicator);
    })();
  </script>
  </br> 
  <hr style="height:1.5px;border-width:0;color:rgba(188, 188, 188, 0.589);background-color:rgba(129, 129, 129, 0.306)"> 

